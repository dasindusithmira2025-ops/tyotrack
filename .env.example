# Frontend (Vite)
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:3061

# Backend (Next.js API)
DATABASE_URL=postgresql://postgres:password@localhost:5432/tyotrack?schema=public
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3061
ENABLE_TEST_LOGIN=true
TEST_LOGIN_PASSWORD=password123
AUTO_SEED=false
SHIFT_REMINDER_RUNNER_TOKEN=replace-with-a-long-random-runner-token
SHIFT_REMINDER_AUTORUN=true
SHIFT_REMINDER_AUTORUN_INTERVAL_MS=60000

SHIFT_EMAIL_MODE=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

