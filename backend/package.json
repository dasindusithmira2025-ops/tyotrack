{
    "name": "tyotrack-backend",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "next dev -p 3061",
        "build": "next build",
        "start": "next start -p 3061",
        "prisma:generate": "prisma generate --schema prisma/schema.prisma",
        "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
        "prisma:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
        "seed": "tsx scripts/seed.ts",
        "test": "vitest run",
        "smoke:reminders": "tsx scripts/reminder-smoke.ts"
    },
    "dependencies": {
        "@prisma/client": "^6.19.2",
        "bcryptjs": "^2.4.3",
        "jszip": "^3.10.1",
        "luxon": "^3.7.2",
        "next": "^16.0.0",
        "next-auth": "^5.0.0-beta.29",
        "nodemailer": "^7.0.7",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "xlsx": "0.18.5",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/luxon": "^3.4.2",
        "@types/node": "^22.14.0",
        "@types/nodemailer": "6.4.17",
        "@types/react": "19.2.14",
        "prisma": "^6.19.2",
        "tsx": "^4.20.5",
        "typescript": "~5.8.2",
        "vitest": "^3.2.4"
    }
}
